<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.WorkshopController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <TableView fx:id="workshopTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleColumn" text="Title" prefWidth="160" />
            <TableColumn fx:id="instructorColumn" text="Instructor" prefWidth="120" />
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="130" />
            <TableColumn fx:id="durationColumn" text="Duration (min)" prefWidth="90" />
            <TableColumn fx:id="maxColumn" text="Max" prefWidth="50" />
            <TableColumn fx:id="priceColumn" text="Price" prefWidth="70" />
            <TableColumn fx:id="levelColumn" text="Level" prefWidth="90" />
            <TableColumn fx:id="locationColumn" text="Location" prefWidth="130" />
        </columns>
    </TableView>
    <HBox spacing="10.0" alignment="CENTER_RIGHT">
        <Button text="Add Workshop" onAction="#handleAdd" />
        <Button text="Edit" onAction="#handleEdit" />
        <Button text="Delete" onAction="#handleDelete" />
    </HBox>
</VBox>
