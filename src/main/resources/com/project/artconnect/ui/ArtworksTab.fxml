<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.artconnect.ui.ArtworkController">
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <TableView fx:id="artworkTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="titleColumn" text="Title" prefWidth="180" />
            <TableColumn fx:id="artistColumn" text="Artist" prefWidth="130" />
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="90" />
            <TableColumn fx:id="mediumColumn" text="Medium" prefWidth="90" />
            <TableColumn fx:id="yearColumn" text="Year" prefWidth="60" />
            <TableColumn fx:id="priceColumn" text="Price" prefWidth="90" />
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="90" />
            <TableColumn fx:id="tagsColumn" text="Tags" prefWidth="150" />
        </columns>
    </TableView>
    <HBox spacing="10.0" alignment="CENTER_RIGHT">
        <Button text="Add Artwork" onAction="#handleAdd" />
        <Button text="Edit" onAction="#handleEdit" />
        <Button text="Delete" onAction="#handleDelete" />
    </HBox>
</VBox>
