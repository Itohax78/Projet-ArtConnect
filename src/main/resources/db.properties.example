# =============================================================================
# ArtConnect Pro — Configuration de la base de données (TEMPLATE)
# =============================================================================
# Pour configurer votre environnement local :
#   1. Copiez ce fichier :  cp db.properties.example db.properties
#   2. Modifiez db.properties avec VOS identifiants MySQL
#   3. Ne commitez JAMAIS db.properties (il est dans le .gitignore)
# =============================================================================

db.driver=com.mysql.cj.jdbc.Driver
db.url=jdbc:mysql://localhost:3306/artconnect_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&useUnicode=true&characterEncoding=UTF-8
db.user=root
db.password=VOTRE_MOT_DE_PASSE_ICI
